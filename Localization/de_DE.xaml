    <!-- Plugin identity -->
    <sys:String x:Key="LOC_SunshineLibrary_Name">Sunshine</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Description">Spiele per Moonlight von Sunshine-Hosts streamen.</sys:String>

    <!-- Main menu -->
