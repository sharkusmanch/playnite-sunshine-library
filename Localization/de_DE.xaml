    <sys:String x:Key="LOC_SunshineLibrary_Menu_ResyncAll">Alle Hosts neu synchronisieren</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_TestClient">Streaming-Client testen</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_HostStatus">Host-Status…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_CleanOrphans">Verwaiste Overrides aufräumen</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_NoHosts">Keine Hosts konfiguriert. Füge in den Plugin-Einstellungen einen Host hinzu.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_Ok">online ({0}, {1} Apps)</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_Fail">nicht erreichbar (fehlgeschlagen bei {0})</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CleanOrphans_Done">{0} verwaiste Override(s) von {1} Einträgen insgesamt bereinigt.</sys:String>

