    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Keep">Verweesde games bewaren (als niet-geïnstalleerd markeren)</sys:String>

    <!-- Host field: enabled help -->
    <sys:String x:Key="LOC_SunshineLibrary_HostField_Enabled_Help">Uitschakelen om deze host in de instellingen te bewaren maar over te slaan tijdens bibliotheeksyncs. Handig voor hosts die vaak offline zijn.</sys:String>

