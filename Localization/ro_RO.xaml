    <!-- Plugin identity -->
    <sys:String x:Key="LOC_SunshineLibrary_Name">Sunshine / Apollo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Description">Transmite jocuri din gazde Sunshine sau Apollo prin Moonlight.</sys:String>

    <!-- Main menu -->
    <sys:String x:Key="LOC_SunshineLibrary_MenuSection">Sunshine / Apollo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_ResyncAll">Resincronizează toate gazdele</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_TestClient">Testează clientul de streaming</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_HostStatus">Stare gazdă…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_CleanOrphans">Curăță suprascrierile orfane</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_NoHosts">Nicio gazdă configurată. Adaugă o gazdă din setările pluginului.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_Ok">online ({0}, {1} aplicații)</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_Fail">inaccesibil (a eșuat la {0})</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CleanOrphans_Done">S-au curățat {0} suprascriere(i) orfane din totalul de {1} intrări.</sys:String>

