    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Static">Moștenește: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Bitrate">Moștenește: {0} Kbps</sys:String>
