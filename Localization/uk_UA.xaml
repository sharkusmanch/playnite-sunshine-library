    <sys:String x:Key="LOC_SunshineLibrary_Hosts_Remove">Видалити вибраний</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Hosts_RemoveConfirm">Видалити хост «{0}» із SunshineLibrary? Облікові дані та кеш для цього хоста також буде видалено. Записи в бібліотеці Playnite для цього хоста позначаться як невстановлені під час наступної синхронізації.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Label">Мітка</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Address">Адреса</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Port">Порт</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Flavor">Різновид</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Enabled">Увімкнено</sys:String>

    <!-- Settings: Client tab -->
    <sys:String x:Key="LOC_SunshineLibrary_Client_Heading">Шлях до виконуваного файлу Moonlight</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Browse">Огляд…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Browse_Title">Виберіть moonlight-qt.exe</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_PathHelp">Залиште порожнім для автоматичного пошуку у стандартних розташуваннях (Program Files, LocalAppData).</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Test">Перевірити клієнт трансляції</sys:String>

    <!-- Settings: General tab -->
    <sys:String x:Key="LOC_SunshineLibrary_Settings_NotificationMode">Сповіщення</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Always">Завжди — показувати стан синхронізації та помилки</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_OnUpdateOnly">Лише за змін — мовчати, коли нічого не змінилося</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Never">Ніколи — показувати лише критично важливі для безпеки сповіщення</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Help">Події, критичні для безпеки та запуску (помилка автентифікації, невідповідність сертифіката, відсутнє закріплення, недоступний клієнт), завжди показуються незалежно від цього параметра.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_DangerZone">Зона ризику</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAll">Відкликати всі збережені облікові дані</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllConfirm">Видалити всі збережені паролі та закріплення сертифікатів? Вам доведеться повторно ввести облікові дані та підтвердити відбиток сертифіката кожного хоста під час наступної синхронізації.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllDone">Усі збережені облікові дані відкликано.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllHelp">Скористайтеся цим, якщо підозрюєте, що файл параметрів було скопійовано, або хочете почати з чистого аркуша. Хости зі списку не видаляються — лише збережені паролі.</sys:String>

