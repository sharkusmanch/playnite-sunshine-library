    <!-- Add/Edit Host dialog — orphan field -->
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans">Автовидалення осиротілих ігор</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Help">Перевизначення для конкретного хоста щодо видалення осиротілих ігор під час синхронізації. &quot;Успадковувати&quot; — використовувати глобальний параметр на вкладці «Загальні».</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Inherit">Успадкувати з глобального параметра</sys:String>
