    <sys:String x:Key="LOC_SunshineLibrary_Description">Трансляція ігор із хостів Sunshine або Apollo через Moonlight.</sys:String>

    <!-- Main menu -->
    <sys:String x:Key="LOC_SunshineLibrary_MenuSection">Sunshine / Apollo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_ResyncAll">Пересинхронізувати всі хости</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_TestClient">Перевірити клієнт трансляції</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_HostStatus">Стан хостів…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_CleanOrphans">Очистити осиротілі перевизначення</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_NoHosts">Хости не налаштовано. Додайте хост у параметрах плагіна.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_Ok">у мережі ({0}, застосунків: {1})</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_Fail">недоступний (збій на етапі {0})</sys:String>
