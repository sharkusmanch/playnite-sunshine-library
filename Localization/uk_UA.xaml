    <sys:String x:Key="LOC_SunshineLibrary_HostField_ExcludedAppNames">Виключені назви застосунків (по одній у рядку)</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_ExcludedAppNames_Help">Застосунки з цими назвами (без урахування регістру) не з’являтимуться в Playnite. Попередньо заповнено вбудованими записами Sunshine (Desktop, Steam Big Picture, Terminate) — вилучіть ті, які хочете залишити.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestConnection">Перевірити з’єднання</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_Testing">Перевіряння…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestOk">Перевірку успішно завершено. Різновид: {0}. Знайдено застосунків: {1}.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestFailedAt">Збій на етапі {0}: {1}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_RunTestFirst">Спершу натисніть «Перевірити з’єднання», щоб плагін отримав відбиток сертифіката хоста.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_PinDeclined">Сертифікат не підтверджено. Хост не збережено.</sys:String>

    <!-- Cert pin dialog -->
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Title">Підтвердження сертифіката</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Heading">Довіряти сертифікату для «{0}»?</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_BodyFirstConnect">Sunshine використовує самопідписані сертифікати. Закріпіть відбиток нижче, щоб майбутні підключення звірялися з ним. Якщо ви не налаштовували цей хост, виберіть «Ні».</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_BodyRepin">Відбиток сертифіката для цього хоста змінився. Таке буває після перевстановлення Sunshine — але також може означати, що з’єднання перехоплюється. Підтверджуйте новий відбиток, лише якщо нещодавно перевстановлювали хост.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Fingerprint">Відбиток SHA-256</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_OldFingerprint">Раніше довірений відбиток</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_NewFingerprint">Новий виявлений відбиток</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Subject">Суб’єкт:</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_NotAfter">Дійсний до:</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Guidance">Переконайтеся, що він збігається з відбитком, показаним у</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Trust">Довіряти цьому сертифікату</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Repin">Перезакріпити на новий сертифікат</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Cancel">Скасувати</sys:String>

