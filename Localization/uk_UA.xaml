    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Static">Успадковано: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Bitrate">Успадковано: {0} Kbps</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Codec">Успадковано: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_DisplayMode">Успадковано: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_AudioConfig">Успадковано: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Bool">Успадковано: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_MoonlightDefault">Успадковано: те, що налаштовано в Moonlight</sys:String>

    <!-- Bulk dialog -->
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Title">Масове редагування параметрів трансляції</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Heading">Застосувати параметри трансляції до {0} вибраних ігор</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Help">Позначте поля, які хочете застосувати. Непозначені поля в кожній грі залишаться без змін. Щоб повністю скинути перевизначення, скористайтеся пунктом «Скинути перевизначення трансляції» в контекстному меню.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Apply">Застосувати до {0} ігор</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_ApplyField">Застосувати {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_NothingSelected">Позначте принаймні одне поле для застосування або натисніть «Скасувати».</sys:String>


    <!-- Orphan removal -->
    <sys:String x:Key="LOC_SunshineLibrary_Menu_RemoveOrphanGames">Видалити осиротілі ігри…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_RemoveOrphanGames_None">Осиротілих ігор не знайдено. Усі записи бібліотеки відповідають застосункам на доступних хостах.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_RemoveOrphanGames_Confirm">Видалити {0} осиротіл(у/их) гр(у/и) з бібліотеки? Час у грі, перевизначення трансляції та обкладинки буде видалено назавжди. Хости, що зараз недоступні, пропускаються — їхні ігри ніколи не видаляються автоматично.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_RemoveOrphanGames_Done">Видалено осиротілих ігор: {0}.</sys:String>

    <!-- Settings: General tab — orphan auto-removal -->
    <sys:String x:Key="LOC_SunshineLibrary_Settings_AutoRemoveOrphans">Автовидалення осиротілих ігор під час синхронізації</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_AutoRemoveOrphans_Help">Якщо увімкнено, ігри, яких більше немає на жодному доступному хості, видаляються з Playnite під час наступної синхронізації. Вимкнено за замовчуванням — осиротілі ігри позначаються як невстановлені, зберігаючи час у грі та перевизначення. Хости з резервним кешем (офлайн) ніколи не очищаються незалежно від цього параметра.</sys:String>

    <!-- Settings: tabs -->
    <sys:String x:Key="LOC_SunshineLibrary_Settings_Tab_Defaults">Стандарти трансляції</sys:String>

    <!-- Add/Edit Host dialog — tabs -->
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_Tab_Host">Хост</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_Tab_Defaults">Стандарти трансляції</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_DefaultsHeading">Стандарти трансляції для &quot;{0}&quot;</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_DefaultsHeadingUnnamed">цього хоста</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_DefaultsHelp">Ці значення застосовуються до кожної гри, що транслюється з цього хоста. Перевизначення для окремої гри (правою кнопкою миші) мають пріоритет. Поля зі значенням «Успадковувати» передаються до глобальних стандартів трансляції, а потім до власних налаштувань Moonlight&apos;у.</sys:String>
