    <sys:String x:Key="LOC_SunshineLibrary_Warn_BitrateOutOfRange">Бітрейт {0} Kbps поза припустимим діапазоном (500–500000).</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Warn_FpsOutOfRange">FPS {0} поза припустимим діапазоном (10–480).</sys:String>

