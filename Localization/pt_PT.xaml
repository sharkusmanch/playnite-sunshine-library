<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Plugin identity -->
    <sys:String x:Key="LOC_SunshineLibrary_Name">Sunshine / Apollo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Description">Transmitir jogos a partir de anfitriões Sunshine ou Apollo através do Moonlight.</sys:String>

    <!-- Main menu -->
    <sys:String x:Key="LOC_SunshineLibrary_MenuSection">Sunshine / Apollo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_ResyncAll">Ressincronizar todos os anfitriões</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_TestClient">Testar cliente de transmissão</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_HostStatus">Estado do anfitrião…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_CleanOrphans">Limpar substituições órfãs</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_NoHosts">Não existem anfitriões configurados. Adicione um anfitrião nas definições do plugin.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_Ok">em linha ({0}, {1} apps)</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostStatus_Fail">inacessível (falhou em {0})</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CleanOrphans_Done">Removidas {0} substituição(ões) órfã(s) de um total de {1} entradas.</sys:String>

    <!-- Game menu -->
    <sys:String x:Key="LOC_SunshineLibrary_Menu_StreamingSettings">Definições de transmissão…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_ClearOverrides">Limpar substituições de transmissão</sys:String>

    <!-- Play action -->
    <sys:String x:Key="LOC_SunshineLibrary_PlayAction_Stream">Transmitir com o Moonlight</sys:String>

    <!-- Source label -->
    <sys:String x:Key="LOC_SunshineLibrary_SourcePrefix">Sunshine: {0}</sys:String>

    <!-- Feature tag -->
    <sys:String x:Key="LOC_SunshineLibrary_Feature_GameStreaming">Transmissão de Jogos</sys:String>

    <!-- Notifications: sync -->
    <sys:String x:Key="LOC_SunshineLibrary_Sync_Success">{0}: {1} jogos disponíveis</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Sync_NoChanges">{0}: sem alterações</sys:String>

    <!-- Notifications: host errors -->
    <sys:String x:Key="LOC_SunshineLibrary_Error_Unreachable">{0}: anfitrião inacessível. A mostrar jogos em cache.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Error_Timeout">{0}: o pedido expirou. A mostrar jogos em cache.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Error_AuthFailed">{0}: falha de autenticação. Atualize as credenciais nas definições.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Error_CertMismatch_Title">{0}: certificado alterado</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Error_CertMismatch_Body">O certificado de {0} foi alterado. Isto pode acontecer caso o Sunshine tenha sido reinstalado, ou pode significar que alguém está a intercetar a ligação. Abra as definições para rever e voltar a fixar.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Error_MissingPin">{0}: certificado não fixado. Configure este anfitrião nas definições para continuar a sincronizar.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Error_ServerError">{0}: o servidor devolveu um erro ({1}).</sys:String>

    <!-- Notifications: client -->
    <sys:String x:Key="LOC_SunshineLibrary_Error_ClientNotInstalled">O Moonlight não está instalado ou o caminho configurado é inválido. Instale o Moonlight e tente novamente.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Error_ClientLaunchFailed">Não foi possível iniciar o Moonlight: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Info_ClientInstalled">Moonlight encontrado em {0}</sys:String>

    <!-- Pre-launch warnings -->
    <sys:String x:Key="LOC_SunshineLibrary_Warn_HdrWithH264">HDR requer HEVC ou AV1, mas o codec selecionado é H.264. HDR será desativado nesta sessão.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Warn_BitrateOutOfRange">Bitrate {0} Kbps está fora do intervalo válido (500–500000).</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Warn_FpsOutOfRange">FPS {0} está fora do intervalo válido (10–480).</sys:String>

    <!-- Settings: tabs -->
    <sys:String x:Key="LOC_SunshineLibrary_Settings_Tab_Hosts">Anfitriões</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_Tab_Client">Cliente de Transmissão</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_Tab_General">Geral</sys:String>

    <!-- Settings: Hosts tab -->
    <sys:String x:Key="LOC_SunshineLibrary_Hosts_Add">Adicionar anfitrião…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Hosts_Edit">Editar selecionado…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Hosts_Remove">Remover selecionado</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Hosts_RemoveConfirm">Remover o anfitrião "{0}" do SunshineLibrary? A credencial e a cache específicas deste anfitrião também serão eliminadas. As entradas da biblioteca do Playnite para este anfitrião ficarão como desinstaladas na próxima sincronização.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Label">Etiqueta</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Address">Endereço</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Port">Porta</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Flavor">Variante</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Enabled">Ativo</sys:String>

    <!-- Settings: Client tab -->
    <sys:String x:Key="LOC_SunshineLibrary_Client_Heading">Caminho do executável do Moonlight</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Browse">Procurar…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Browse_Title">Selecionar moonlight-qt.exe</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_PathHelp">Deixe em branco para procurar automaticamente nas localizações padrão de instalação (Program Files, LocalAppData).</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Test">Testar cliente de transmissão</sys:String>

    <!-- Settings: General tab -->
    <sys:String x:Key="LOC_SunshineLibrary_Settings_NotificationMode">Notificações</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Always">Sempre — mostrar estado de sincronização e erros</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_OnUpdateOnly">Apenas em alterações — silencioso quando nada muda</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Never">Nunca — mostrar apenas notificações críticas de segurança</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Help">Eventos críticos de segurança e de arranque (falha de autenticação, discrepância de certificado, fixação em falta, cliente indisponível) são sempre apresentados, independentemente desta definição.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_DangerZone">Zona de perigo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAll">Revogar todas as credenciais armazenadas</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllConfirm">Eliminar todas as palavras-passe e fixações de certificado armazenadas? Terá de reintroduzir as credenciais e reconfirmar a impressão digital do certificado de cada anfitrião na próxima sincronização.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllDone">Todas as credenciais armazenadas foram revogadas.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllHelp">Use esta opção se suspeitar que um ficheiro de definições foi copiado ou se quiser começar de novo. Não remove anfitriões da lista — apenas as palavras-passe armazenadas.</sys:String>

    <!-- Add/Edit Host dialog -->
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TitleAdd">Adicionar anfitrião Sunshine / Apollo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TitleEdit">Editar anfitrião Sunshine / Apollo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_Label">Etiqueta</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_Address">Endereço (nome de anfitrião ou IP)</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_Port">Porta</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AdminUser">Nome de utilizador de administrador</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AdminPassword">Palavra-passe de administrador</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_Enabled">Ativo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_ExcludedAppNames">Nomes de apps excluídos (um por linha)</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_ExcludedAppNames_Help">Apps cujos nomes correspondam (sem distinção entre maiúsculas e minúsculas) não aparecerão no Playnite. Preenchido inicialmente com os predefinidos do Sunshine (Desktop, Steam Big Picture, Terminate) — remova os que pretender manter.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestConnection">Testar ligação</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_Testing">A testar…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestOk">Teste bem-sucedido. Variante: {0}. Apps encontrados: {1}.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestFailedAt">Teste falhou no passo {0}: {1}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_RunTestFirst">Execute "Testar ligação" primeiro para que o plugin possa observar a impressão digital do certificado do anfitrião.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_PinDeclined">O certificado não foi confirmado. Anfitrião não guardado.</sys:String>

    <!-- Cert pin dialog -->
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Title">Confirmar certificado</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Heading">Confiar no certificado de "{0}"?</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_BodyFirstConnect">Sunshine e Apollo utilizam certificados autoassinados. Fixe a impressão digital apresentada abaixo para que ligações futuras sejam verificadas contra ela. Se não foi o utilizador que configurou este anfitrião, responda Não.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_BodyRepin">A impressão digital do certificado deste anfitrião foi alterada. Isto pode acontecer caso o Sunshine tenha sido reinstalado — ou pode significar que alguém está a intercetar a ligação. Confirme a nova impressão digital apenas se tiver reinstalado o anfitrião recentemente.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Fingerprint">Impressão digital SHA-256</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_OldFingerprint">Impressão digital anteriormente fidedigna</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_NewFingerprint">Nova impressão digital observada</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Subject">Assunto:</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_NotAfter">Válido até:</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Guidance">Verifique se corresponde à impressão digital apresentada em</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Trust">Confiar neste certificado</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Repin">Voltar a fixar no novo certificado</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Cancel">Cancelar</sys:String>

    <!-- Validation -->
    <sys:String x:Key="LOC_SunshineLibrary_Validation_LabelRequired">A etiqueta é obrigatória.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Validation_AddressRequired">O endereço é obrigatório.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Validation_AddressChars">O endereço não pode conter esquemas, caminhos, espaços em branco ou carateres de shell. Utilize apenas um nome de anfitrião ou IP.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Validation_PortRange">A porta tem de estar entre 1 e 65535.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Validation_MoonlightPathInvalid">O executável do Moonlight não foi encontrado no caminho configurado.</sys:String>

    <!-- Common -->
    <sys:String x:Key="LOC_SunshineLibrary_Common_Ok">OK</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Common_Cancel">Cancelar</sys:String>

    <!-- Game context menu -->
    <sys:String x:Key="LOC_SunshineLibrary_Menu_BulkEdit">Editar definições de transmissão para {0} jogos selecionados…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_ClearOverridesSelection">Limpar substituições de transmissão para {0} jogos selecionados</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Menu_ClearOverridesConfirm">Limpar substituições de transmissão para {0} jogos selecionados? Esta ação não pode ser anulada.</sys:String>

    <!-- Per-game override dialog -->
    <sys:String x:Key="LOC_SunshineLibrary_OverrideDialog_Title">Definições de transmissão — {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideDialog_Group_Display">Vídeo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideDialog_Group_Encoding">Codificação</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideDialog_Group_Performance">Desempenho</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideDialog_Group_Output">Saída</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideDialog_Group_Advanced">Avançado</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideDialog_ClearAll">Limpar todas as substituições</sys:String>

    <!-- Per-game override field labels -->
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_Resolution">Resolução</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_Fps">Imagens por segundo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_Hdr">HDR</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_Bitrate">Bitrate</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_VideoCodec">Codec de vídeo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_Yuv444">Croma YUV 4:4:4</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_FramePacing">Cadência de imagens</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_GameOptimization">Otimização do jogo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_DisplayMode">Modo de apresentação</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_AudioConfig">Configuração de áudio</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_ExtraArgs">Argumentos adicionais do Moonlight</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_ExtraArgs_Help">Avançado. Anexados literalmente à linha de comandos do moonlight-qt. Divididos por espaços em branco — sem aspas de shell.</sys:String>

    <!-- Override mode labels -->
    <sys:String x:Key="LOC_SunshineLibrary_Override_Mode_Inherit">Herdar</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Mode_Auto">Automático (igual ao cliente)</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Mode_Static">Valor fixo</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Hdr_On">Forçar ativado</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Hdr_Off">Forçar desativado</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_OverrideField">Substituir</sys:String>

    <!-- Fallback hint labels -->
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Auto">Herda: deteção automática a partir do ecrã do cliente</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Static">Herda: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Bitrate">Herda: {0} Kbps</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Codec">Herda: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_DisplayMode">Herda: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_AudioConfig">Herda: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_Bool">Herda: {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_MoonlightDefault">Herda: o que estiver configurado no Moonlight</sys:String>

    <!-- Bulk dialog -->
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Title">Edição em massa das definições de transmissão</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Heading">Aplicar definições de transmissão a {0} jogos selecionados</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Help">Selecione os campos que pretende aplicar. Os campos não selecionados ficam inalterados em cada jogo. Para eliminar completamente as substituições, utilize "Limpar substituições de transmissão" no menu do botão direito.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Apply">Aplicar a {0} jogos</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_ApplyField">Aplicar {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_NothingSelected">Selecione pelo menos um campo para aplicar, ou clique em Cancelar.</sys:String>


    <!-- BEGIN: untranslated — English fallback until translations are provided -->
    <sys:String x:Key="LOC_SunshineLibrary_Menu_RemoveOrphanGames">Remove orphaned games…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_RemoveOrphanGames_None">No orphaned games found. All your library entries match apps currently on reachable hosts.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_RemoveOrphanGames_Confirm">Remove {0} orphaned game(s) from the library? Playtime, per-game streaming overrides, and covers will be permanently deleted. Hosts that are currently offline are skipped — their games are never pruned automatically.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_RemoveOrphanGames_Done">Removed {0} orphaned game(s).</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_AutoRemoveOrphans">Auto-remove orphaned games on sync</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_AutoRemoveOrphans_Help">When enabled, games that no longer exist on any reachable host are deleted from Playnite on the next sync. Off by default — orphans are marked uninstalled instead, preserving playtime and overrides. Cache-fallback hosts (offline) are never pruned regardless of this setting.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_Tab_Defaults">Streaming Defaults</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_Tab_Host">Host</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_Tab_Defaults">Streaming defaults</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_DefaultsHeading">Streaming defaults for &quot;{0}&quot;</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_DefaultsHeadingUnnamed">this host</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_DefaultsHelp">These values apply to every game streamed from this host. Per-game overrides (right-click a game) take precedence. Fields set to Inherit fall through to the global streaming defaults, then to Moonlight&apos;s own configured values.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestCancelled">Test cancelled.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestStepStatus">{0}: {1}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans">Auto-remove orphaned games</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Help">Per-host override for orphan deletion on sync. &quot;Inherit&quot; defers to the global setting on the General tab.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Inherit">Inherit from global setting</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Delete">Delete orphaned games</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Keep">Keep orphaned games (mark uninstalled)</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_Enabled_Help">Disable to keep this host in settings but skip it during library syncs. Useful for hosts that are often offline.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_AutoDetect">Auto-detect</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_AutoDetect_None">Moonlight was not found in PATH, Scoop, Winget, or any standard install location. Install Moonlight or browse to its executable.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_AutoDetect_FoundOne">Found Moonlight at:&#x0a;{0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_AutoDetect_Pick">Multiple Moonlight installs found. Select one:</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Defaults_Heading">Default Moonlight options</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Defaults_Help">These values apply to every streamed game. Per-host defaults (on the Hosts tab) and per-game overrides (right-click a game) take precedence over these. Fields set to Inherit fall through to Moonlight&apos;s own configured defaults.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Defaults_ResetToBuiltin">Reset to built-in defaults</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Defaults_ResetConfirm">Reset all global streaming defaults? Resolution, FPS, and HDR will revert to Auto (match client); all other fields will revert to Inherit.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_ShowStats">Show stream stats</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Fallback_BitrateAuto">Auto-calculated from resolution × fps (e.g. 1080p/60 → 20 Mbps, 4K/60 → 80 Mbps; YUV 4:4:4 doubles this)</sys:String>
    <!-- END: untranslated -->

</ResourceDictionary>
