    <sys:String x:Key="LOC_SunshineLibrary_HostField_AdminUser">Nom d'utilisateur administrateur</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AdminPassword">Mot de passe administrateur</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_ApiToken">API Token</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_ApiToken_Help">Vibepollo/Apollo: authenticate with a Bearer token instead of username/password. Generate in the web console (Admin → API Tokens). Required scopes: GET /api/config, /api/playnite/status, /api/apps, /api/playnite/games; POST /api/playnite/force_sync, /api/apps/close.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_Enabled">Activé</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_ExcludedAppNames">Noms d'applications exclus (un par ligne)</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_ExcludedAppNames_Help">Les applications correspondant à ces noms (sans distinction de casse) n'apparaîtront pas dans Playnite. Pré-rempli avec les valeurs par défaut de Sunshine (Desktop, Steam Big Picture, Terminate) — retirez celles que vous voulez conserver.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestConnection">Tester la connexion</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_Testing">Test en cours…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestOk">Test réussi. Variante : {0}. Applications trouvées : {1}.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestFailedAt">Le test a échoué à l'étape {0} : {1}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_RunTestFirst">Lancez d'abord « Tester la connexion » pour que le plugin puisse relever l'empreinte du certificat de l'hôte.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_PinDeclined">Le certificat n'a pas été confirmé. Hôte non enregistré.</sys:String>

    <!-- Cert pin dialog -->
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Title">Confirmer le certificat</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Heading">Faire confiance au certificat de « {0} » ?</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_BodyFirstConnect">Sunshine utilise des certificats auto-signés. Épinglez l'empreinte ci-dessous pour que les futures connexions soient vérifiées. Si vous n'avez pas configuré vous-même cet hôte, répondez Non.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_BodyRepin">L'empreinte du certificat de cet hôte a changé. Cela peut se produire si Sunshine a été réinstallé — ou cela peut signifier que quelqu'un intercepte la connexion. Confirmez la nouvelle empreinte uniquement si vous avez récemment réinstallé l'hôte.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Fingerprint">Empreinte SHA-256</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_OldFingerprint">Empreinte précédemment approuvée</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_NewFingerprint">Nouvelle empreinte observée</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Subject">Sujet :</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_NotAfter">Valide jusqu'au :</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Guidance">Vérifiez que cela correspond à l'empreinte affichée à</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Trust">Faire confiance à ce certificat</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Repin">Ré-épingler sur le nouveau certificat</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Cancel">Annuler</sys:String>

    <!-- Validation -->
