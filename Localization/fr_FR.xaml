    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Flavor">Variante</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostCol_Enabled">Activé</sys:String>

    <!-- Settings: Client tab -->
    <sys:String x:Key="LOC_SunshineLibrary_Client_Heading">Chemin de l'exécutable Moonlight</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Browse">Parcourir…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Browse_Title">Sélectionner moonlight-qt.exe</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_PathHelp">Laissez vide pour détecter automatiquement les emplacements d'installation standard (Program Files, LocalAppData).</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Test">Tester le client de streaming</sys:String>

    <!-- Settings: General tab -->
    <sys:String x:Key="LOC_SunshineLibrary_Settings_NotificationMode">Notifications</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Always">Toujours — afficher l'état de synchronisation et les erreurs</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_OnUpdateOnly">Aux changements seulement — silencieux quand rien ne change</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Never">Jamais — afficher uniquement les notifications critiques de sécurité</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Help">Les événements critiques pour la sécurité et le lancement (échec d'authentification, désaccord de certificat, épinglage manquant, client indisponible) sont toujours affichés quel que soit ce paramètre.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_DangerZone">Zone de danger</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAll">Révoquer tous les identifiants stockés</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllConfirm">Supprimer tous les mots de passe et épinglages de certificat stockés ? Vous devrez ressaisir les identifiants et reconfirmer l'empreinte du certificat de chaque hôte à la prochaine synchronisation.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllDone">Tous les identifiants stockés ont été révoqués.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllHelp">Utilisez ceci si vous soupçonnez qu'un fichier de paramètres a été copié ou si vous voulez recommencer à zéro. Cela ne supprime pas les hôtes de la liste — uniquement les mots de passe stockés.</sys:String>

