    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_Bitrate">Datový tok</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_VideoCodec">Video kodek</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_Yuv444">Barvonosný signál YUV 4:4:4</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_FramePacing">Časování snímků</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_GameOptimization">Optimalizace hry</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_DisplayMode">Režim zobrazení</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_AudioConfig">Konfigurace zvuku</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_ExtraArgs">Další argumenty Moonlight</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_ExtraArgs_Help">Pokročilé. Připojeno doslovně k příkazovému řádku moonlight-qt. Rozděleno podle mezer — žádné shellové uvozování.</sys:String>

