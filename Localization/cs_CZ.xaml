    <sys:String x:Key="LOC_SunshineLibrary_Override_Mode_Static">Pevná hodnota</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Override_Hdr_On">Vynutit zapnuto</sys:String>
