    <!-- Settings: General tab -->
    <sys:String x:Key="LOC_SunshineLibrary_Settings_NotificationMode">Powiadomienia</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Always">Zawsze — pokazuj status synchronizacji i błędy</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_OnUpdateOnly">Tylko przy zmianach — cisza, gdy nic się nie zmienia</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Never">Nigdy — pokazuj tylko krytyczne powiadomienia bezpieczeństwa</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Notif_Help">Zdarzenia krytyczne dla bezpieczeństwa i uruchamiania (niepowodzenie uwierzytelniania, niezgodność certyfikatu, brak przypięcia, niedostępność klienta) są zawsze wyświetlane niezależnie od tego ustawienia.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_DangerZone">Strefa zagrożenia</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAll">Unieważnij wszystkie zapisane dane logowania</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllConfirm">Usunąć wszystkie zapisane hasła i przypięcia certyfikatów? Przy następnej synchronizacji będziesz musiał ponownie wprowadzić dane logowania i ponownie potwierdzić odcisk certyfikatu każdego hosta.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllDone">Wszystkie zapisane dane logowania zostały unieważnione.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_RevokeAllHelp">Użyj tej opcji, jeśli podejrzewasz, że plik ustawień został skopiowany lub chcesz zacząć od nowa. Nie usuwa to hostów z listy — tylko zapisane hasła.</sys:String>

    <!-- Add/Edit Host dialog -->
