    <!-- Bulk dialog -->
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Title">Masowa edycja ustawień strumieniowania</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Heading">Zastosuj ustawienia strumieniowania do {0} wybranych gier</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Help">Zaznacz pola, które chcesz zastosować. Niezaznaczone pola pozostaną bez zmian w każdej grze. Aby całkowicie usunąć nadpisania, użyj „Wyczyść nadpisania strumieniowania” z menu kontekstowego.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_Apply">Zastosuj do {0} gier</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_ApplyField">Zastosuj {0}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_BulkDialog_NothingSelected">Zaznacz co najmniej jedno pole do zastosowania lub kliknij Anuluj.</sys:String>


    <!-- Menu: orphan removal -->
    <sys:String x:Key="LOC_SunshineLibrary_Menu_RemoveOrphanGames">Usuń osierocone gry…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_RemoveOrphanGames_None">Nie znaleziono osieroconych gier. Wszystkie wpisy w bibliotece odpowiadają aplikacjom dostępnym na osiągalnych hostach.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_RemoveOrphanGames_Confirm">Usunąć {0} osieroconych gier z biblioteki? Czas gry, nadpisania strumieniowania dla poszczególnych gier oraz okładki zostaną trwale usunięte. Hosty, które są obecnie niedostępne, są pomijane — ich gry nigdy nie są usuwane automatycznie.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_RemoveOrphanGames_Done">Usunięto {0} osieroconych gier.</sys:String>

    <!-- Settings: General tab — orphan removal -->
    <sys:String x:Key="LOC_SunshineLibrary_Settings_AutoRemoveOrphans">Automatycznie usuwaj osierocone gry przy synchronizacji</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Settings_AutoRemoveOrphans_Help">Po włączeniu gry, które nie istnieją już na żadnym osiągalnym hoście, są usuwane z Playnite przy następnej synchronizacji. Domyślnie wyłączone — osierocone gry są oznaczane jako odinstalowane, co zachowuje czas gry i nadpisania. Hosty działające z pamięci podręcznej (offline) nigdy nie są czyszczone niezależnie od tego ustawienia.</sys:String>

    <!-- Settings: tabs -->
    <sys:String x:Key="LOC_SunshineLibrary_Settings_Tab_Defaults">Domyślne strumieniowanie</sys:String>

    <!-- Add/Edit Host dialog: tabs -->
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_Tab_Host">Host</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_Tab_Defaults">Domyślne strumieniowanie</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_DefaultsHeading">Domyślne strumieniowanie dla &quot;{0}&quot;</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_DefaultsHeadingUnnamed">tego hosta</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_DefaultsHelp">Te wartości mają zastosowanie do każdej gry strumieniowanej z tego hosta. Nadpisania dla poszczególnych gier (kliknij grę prawym przyciskiem myszy) mają pierwszeństwo. Pola ustawione na Dziedzicz przechodzą do globalnych ustawień domyślnych strumieniowania, a następnie do własnych skonfigurowanych wartości Moonlight.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestCancelled">Test anulowany.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestStepStatus">{0}: {1}</sys:String>

    <!-- Add/Edit Host dialog: orphan removal field -->
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans">Automatycznie usuwaj osierocone gry</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Help">Nadpisanie usuwania osieroconych gier przy synchronizacji dla tego hosta. Opcja &quot;Dziedzicz&quot; stosuje ustawienie globalne z karty Ogólne.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Inherit">Dziedzicz z ustawienia globalnego</sys:String>
