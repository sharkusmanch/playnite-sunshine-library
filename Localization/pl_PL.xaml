    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_KeepAwake">Utrzymuj system aktywnym</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_CaptureSystemKeys">Przechwytuj klawisze systemowe</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_ExtraArgs">Dodatkowe argumenty Moonlight</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_ExtraArgs_Help">Zaawansowane. Dołączane dosłownie do wiersza poleceń moonlight-qt. Dzielone po spacjach — bez cudzysłowów powłoki.</sys:String>

