    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestFailedAt">Test nie powiódł się w kroku {0}: {1}</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_RunTestFirst">Najpierw uruchom „Przetestuj połączenie”, aby wtyczka mogła odczytać odcisk certyfikatu hosta.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_PinDeclined">Certyfikat nie został potwierdzony. Host nie został zapisany.</sys:String>

    <!-- Cert pin dialog -->
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Title">Potwierdź certyfikat</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Heading">Zaufać certyfikatowi dla „{0}”?</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_BodyFirstConnect">Sunshine i Apollo używają certyfikatów podpisanych samodzielnie. Przypnij poniższy odcisk, aby przyszłe połączenia były względem niego weryfikowane. Jeśli to nie Ty konfigurowałeś tego hosta, wybierz Nie.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_BodyRepin">Odcisk certyfikatu dla tego hosta uległ zmianie. Może to oznaczać ponowną instalację Sunshine — albo to, że ktoś przechwytuje połączenie. Potwierdź nowy odcisk tylko wtedy, gdy niedawno ponownie zainstalowałeś hosta.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Fingerprint">Odcisk SHA-256</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_OldFingerprint">Wcześniej zaufany odcisk</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_NewFingerprint">Zaobserwowany nowy odcisk</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Subject">Podmiot:</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_NotAfter">Ważny do:</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Guidance">Sprawdź, czy zgadza się z odciskiem pokazanym w</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Trust">Zaufaj temu certyfikatowi</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Repin">Przypnij nowy certyfikat</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_CertDialog_Cancel">Anuluj</sys:String>

    <!-- Validation -->
    <sys:String x:Key="LOC_SunshineLibrary_Validation_LabelRequired">Etykieta jest wymagana.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Validation_AddressRequired">Adres jest wymagany.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Validation_AddressChars">Adres nie może zawierać schematów, ścieżek, spacji ani znaków powłoki. Użyj samej nazwy hosta lub IP.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Validation_PortRange">Port musi mieścić się w zakresie od 1 do 65535.</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Validation_MoonlightPathInvalid">Plik wykonywalny Moonlight nie został znaleziony w skonfigurowanej ścieżce.</sys:String>

