    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TitleEdit">Edytuj hosta Sunshine</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_Label">Etykieta</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_Address">Adres (nazwa hosta lub IP)</sys:String>
