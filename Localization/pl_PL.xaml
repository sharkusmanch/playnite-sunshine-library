    <sys:String x:Key="LOC_SunshineLibrary_Client_Browse">Przeglądaj…</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_Browse_Title">Wybierz moonlight-qt.exe</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_Client_PathHelp">Pozostaw puste, aby automatycznie wykryć standardowe lokalizacje instalacji (Program Files, LocalAppData).</sys:String>
