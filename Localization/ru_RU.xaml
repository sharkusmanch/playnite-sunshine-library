    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_Yuv444">Цветность YUV 4:4:4</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_FramePacing">Ритм кадров</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_OverrideField_GameOptimization">Оптимизация игры</sys:String>
