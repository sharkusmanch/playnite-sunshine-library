    <sys:String x:Key="LOC_SunshineLibrary_HostDialog_TestStepStatus">{0}: {1}</sys:String>

    <!-- Add/Edit Host dialog: per-host orphan override -->
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans">Автоматически удалять осиротевшие игры</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Help">Переопределение удаления осиротевших записей при синхронизации для данного хоста. &quot;Наследовать&quot; использует глобальную настройку на вкладке «Общие».</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Inherit">Наследовать из глобальных настроек</sys:String>
    <sys:String x:Key="LOC_SunshineLibrary_HostField_AutoRemoveOrphans_Delete">Удалять осиротевшие игры</sys:String>
